# Copy to .env and adjust as needed.
#
# Pick a host port that is NOT used by your other Memos instances.
# Check: docker ps --format '{{.Names}} {{.Ports}}' | grep memos
MEMOS_PORT=5231

TZ=Asia/Shanghai

# Optional: set at build time
# MEMOS_VERSION=dev
# MEMOS_COMMIT=local

# Optional: external database (default is SQLite in ./data)
# MEMOS_DRIVER=postgres
# MEMOS_DSN=postgresql://user:password@host:5432/memos?sslmode=disable
